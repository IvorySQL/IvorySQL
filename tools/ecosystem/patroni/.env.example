PATRONI_SUPERUSER_PASSWORD=replace-with-a-long-admin-password
PATRONI_REPLICATION_PASSWORD=replace-with-a-long-replication-password
PATRONI_API_PASSWORD=replace-with-a-long-api-password
PATRONI_SCOPE=ivorysql-ha
PATRONI_SYNCHRONOUS_MODE=true
